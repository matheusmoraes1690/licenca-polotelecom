# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=false # Mude para 'false' se o banco de dados não suportar conexões SSL (comum em servidores locais/privados)

# Server
PORT=3000
NODE_ENV=development

# Security — gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# Milvus API Integration
MILVUS_API_BASE_URL=https://apiintegracao.milvus.com.br/api
MILVUS_API_TOKEN=

# CORS — origens permitidas separadas por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Admin — senha inicial do primeiro admin (será exigida em formato hash)
ADMIN_INITIAL_PASSWORD=
